#!/usr/bin/env node
// Bin shim — extensionless so it reads as a Unix command (`ecswatch`, not
// `ecswatch.js`). Node resolves the parser via the parent package.json's
// `"type": "module"`, so this file is treated as ESM. The real CLI lives
// in dist/cli.js; keeping a tiny shim keeps `npm link` stable across
// rebuilds (the global symlink never has to update).

import('../dist/cli.js').catch((err) => {
    // eslint-disable-next-line no-console
    console.error('ecswatch: failed to load dist/cli.js — did you run `npm run build`?');
    console.error(err);
    process.exit(1);
});
