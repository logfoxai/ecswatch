{
  "name": "ecswatch",
  "version": "0.0.0-autorel",
  "description": "Beautiful interactive TUI for inspecting AWS ECS services + a CI-friendly streaming mode for GitHub Actions. Optional LLM-assisted root-cause analysis for failed rollouts.",
  "keywords": [
    "aws",
    "ecs",
    "fargate",
    "deploy",
    "tui",
    "cli",
    "ink",
    "github-actions",
    "rollout",
    "watcher"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/logfoxai/ecswatch.git"
  },
  "bugs": {
    "url": "https://github.com/logfoxai/ecswatch/issues"
  },
  "homepage": "https://github.com/logfoxai/ecswatch#readme",
  "type": "module",
  "bin": {
    "ecswatch": "bin/ecswatch"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "test": "NODE_OPTIONS='--import tsx' kizu 'src/**/*.spec.ts'",
    "coverage": "c8 npm test",
    "dev": "node esbuild.config.mjs --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run validate",
    "validate": "npm run lint && npm run typecheck && npm run build && npm run test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.99.0",
    "@aws-sdk/client-cloudwatch-logs": "3.1055.0",
    "@aws-sdk/client-ecs": "3.1055.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "3.1055.0",
    "@aws-sdk/client-sts": "3.1055.0",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "ink": "7.0.4",
    "ink-spinner": "5.0.0",
    "openai": "6.39.0",
    "react": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "c8": "11.0.0",
    "esbuild": "0.28.0",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "kizu": "5.1.0",
    "tsx": "4.22.4",
    "typescript": "5.6.2",
    "typescript-eslint": "8.60.1"
  }
}
